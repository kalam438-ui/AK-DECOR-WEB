rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - name: string (required)
    //   - category: string (required)
    //   - price: number (required)
    //   - oldPrice: number (optional)
    //   - rating: number (optional)
    //   - reviews: int (optional)
    //   - image: string (required)
    //   - isNew: bool (optional)
    //   - isBestSeller: bool (optional)
    //   - isTopRated: bool (optional)
    //   - discount: number (optional)
    //   - featured: bool (optional)
    //
    // Collection: uploads
    // Document ID: uploadId
    // Fields:
    //   - userId: string (required) - UID of the uploader
    //   - imageUrl: string (required) - URL to the image
    //   - createdAt: timestamp (required) - When it was uploaded
    //   - fileName: string (optional) - Original file name
    //
    // Collection: page_content
    // Document ID: pageId
    // Fields:
    //   - pageId: string (required)
    //   - heroTitle: string (required)
    //   - heroSubtitle: string (optional)
    //   - heroImage: string (optional)
    //   - content: string (optional)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.toLower() == "kalam438@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Products collection: Publicly readable, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Page Content collection: Publicly readable, only admin can write
    match /page_content/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Uploads collection: Users can only read/write their own uploads
    match /uploads/{uploadId} {
      function isValidUpload(data) {
        return data.userId is string &&
               data.imageUrl is string && isValidUrl(data.imageUrl) &&
               data.createdAt is timestamp &&
               (data.fileName == null || (data.fileName is string && data.fileName.size() < 255));
      }

      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidUpload(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.userId == resource.data.userId &&
                      isValidUpload(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
